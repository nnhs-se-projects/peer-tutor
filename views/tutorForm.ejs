<%- include('include/_header') %> <%- include('include/_navbar') %>

<style>
  .form-columns {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center; /* center the columns */
  }

  .form-column {
    flex: 1 1 45%; /* allow it to grow and shrink, with a base of 45% */
    min-width: 350px;
    max-width: 700px;
  }

  .orange-box {
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.2);
    width: 100%; /* make it fill the form-column */
    background-color: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .formQuestions {
    font-family: inherit;
    font-weight: 500;
    margin-bottom: 8px;
    color: #333;
  }

  input[type='text'],
  input[type='email'],
  input[type='date'],
  select,
  textarea {
    border-radius: 8px;
    padding: 10px 12px;
    width: 100%;
    border: 1px solid #ccc;
    font-family: inherit;
    margin-bottom: 16px;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    color: #555 !important; /* Grey text color */
    background-color: white;
  }

  input::placeholder,
  select::placeholder,
  textarea::placeholder {
    color: #888 !important;
    opacity: 1;
  }

  input[type='text']:focus,
  input[type='email']:focus,
  input[type='date']:focus,
  select:focus,
  textarea:focus {
    border-color: #ff8800;
    box-shadow: 0 0 0 3px rgba(255, 136, 0, 0.2);
    outline: none;
  }

  fieldset {
    border: none;
    padding: 0;
    margin: 0 0 16px 0;
  }

  fieldset label {
    display: block;
    margin-bottom: 10px;
    color: #333;
  }

  fieldset input[type='radio'] {
    margin-right: 8px;
  }

  .submit {
    background-color: #ff8800;
    color: white !important;
    font-weight: 500;
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
    margin: 30px 0 60px 0;
    display: block;
    width: 200px;
  }

  .submit:hover {
    background-color: #e67a00;
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 6px 10px rgba(0, 0, 0, 0.4);
  }

  .submit:active {
    transform: translateY(0) scale(0.98);
  }

  .black-heading {
    margin-bottom: 24px;
    font-weight: 600;
    color: #ffffff;
  }
</style>

<!-- Main Site -->
<main class="container mx-auto px-4 py-8 flex-grow">
  <div class="container mx-auto px-4 max-w-12xl">
    <h1 class="text-4xl font-bold mb-8 text-center text-white">Tutor Session Form</h1>
    <form>
      <% if (acceptedRequests && acceptedRequests.length > 0) { %>
      <div class="orange-box mb-6" style="max-width: 700px; margin-left: auto; margin-right: auto;">
        <label class="formQuestions font-medium" for="acceptedRequestSelect">Fill from Accepted Request</label>
        <select class="font-medium" id="acceptedRequestSelect">
          <option value="">-- Select an accepted request (optional) --</option>
          <% acceptedRequests.forEach(function(request) { %>
            <option
              value="<%= request._id %>"
              data-student-first="<%= request.studentFirstName %>"
              data-student-last="<%= request.studentLastName %>"
              data-student-id="<%= request.studentID || '' %>"
              data-grade="<%= request.studentGrade || '' %>"
              data-subject="<%= request.subject %>"
              data-class="<%= request.class %>"
              data-period="<%= request.preferredPeriod %>"
              data-date="<%= request.preferredDate ? new Date(request.preferredDate).toISOString().split('T')[0] : '' %>"
              data-topic="<%= request.topic %>"
            >
              <%= request.studentFirstName %> <%= request.studentLastName %> — <%= request.subject %> (<%= request.class %>) — <%= request.preferredDate ? new Date(request.preferredDate).toLocaleDateString() : 'No date' %>
            </option>
          <% }); %>
        </select>
        <input type="hidden" id="tutoringRequestId" name="tutoringRequestId" value="" />
      </div>
      <% } %>

      <div class="form-columns">
        <!-- Left Column (Tutor Information and Session Details) -->
        <div class="form-column">
          <h2 class="black-heading">Tutor</h2>
          <div class="orange-box">
            <label class="formQuestions font-medium" for="tutorFirstName">Tutor First Name</label>
            <input
              type="text"
              class="font-medium"
              id="tutorFirstName"
              name="tutorFirstName"
              value="<%= tutor ? tutor.tutorFirstName : '' %>"
              required
            />

            <label class="formQuestions font-medium" for="tutorLastName">Tutor Last Name</label>
            <input
              type="text"
              class="font-medium"
              id="tutorLastName"
              name="tutorLastName"
              value="<%= tutor ? tutor.tutorLastName : '' %>"
              required
            />

            <label class="formQuestions font-medium" for="tutorID">Tutor ID</label>
            <input type="text" class="font-medium" id="tutorID" name="tutorID" value="<%= tutor ? tutor.tutorID : '' %>" required />

            <label class="formQuestions font-medium" for="sessionDate">Date</label>
            <input type="date" class="font-medium" id="sessionDate" name="sessionDate" required />
            <script>
              // Autofill today's date in Central Time
              (function() {
                const now = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Chicago' }));
                const yyyy = now.getFullYear();
                const mm = String(now.getMonth() + 1).padStart(2, '0');
                const dd = String(now.getDate()).padStart(2, '0');
                document.getElementById('sessionDate').value = yyyy + '-' + mm + '-' + dd;
              })();
            </script>

            <label class="formQuestions font-medium" for="sessionPeriod">Session Period</label>
            <% const tutorPeriod = tutor ? String(tutor.lunchPeriod) + 'th' : ''; %>
            <select class="font-medium" id="sessionPeriod" name="sessionPeriod" required>
              <option value="">Select a Period</option>
              <option value="4th" <%= tutorPeriod === '4th' ? 'selected' : '' %>>4th</option>
              <option value="5th" <%= tutorPeriod === '5th' ? 'selected' : '' %>>5th</option>
              <option value="6th" <%= tutorPeriod === '6th' ? 'selected' : '' %>>6th</option>
              <option value="WIN">WIN</option>
              <option value="RAT">RAT</option>
            </select>

            <label class="formQuestions font-medium" for="department">Department</label>
            <select
              class="font-medium"
              id="department"
              name="department"
              onchange="updateClasses()"
              required
            >
              <option value="">Select a Department</option>
              <option value="Math">Math</option>
              <option value="English">English</option>
              <option value="CTE">CTE</option>
              <option value="Fine Arts">Fine Arts</option>
              <option value="Wellness">Wellness</option>
              <option value="World & Classical Language">World & Classical Language</option>
              <option value="Science">Science</option>
              <option value="Social Studies">Social Studies</option>
              <option value="EL classes">EL classes</option>
              <option value="Academic Support">Academic Support</option>
            </select>

            <label class="formQuestions font-medium" for="class">Class</label>
            <select class="font-medium" id="class" name="class" required>
              <option value="">Select a Class</option>
            </select>

            <label class="formQuestions font-medium" for="teacher">Teacher</label>
            <select class="font-medium" id="teacher" name="teacher" required>
              <option value="">Select a Teacher</option>
            </select>

            <label class="formQuestions font-medium" for="FocusOfSession">Session Focus</label>
            <select class="font-medium" id="FocusOfSession" name="FocusOfSession" required>
              <option value="">Select a Focus</option>
              <option value="Conversation">Conversation</option>
              <option value="FERP">FERP(Final Review Packet)</option>
              <option value="TestCorrections">Test corrections or retake requirement</option>
              <option value="WritingEnhancements">Writing enhancement or paper edit</option>
              <option value="Homework">Homework</option>
              <option value="TestOrQuizReview">Test or quiz review</option>
              <option value="ConceptReview">Concept or concept review (no immediate test)</option>
              <option value="Presentation">Speaking / Presentation</option>
              <option value="Organization">Organization</option>
              <option value="StudySkills">General study skills or test taking skills</option>
              <option value="Comprehension">Comprehension</option>
            </select>

            <label class="formQuestions font-medium" for="workaccomplished"
              >Assignment and Work Accomplished</label
            >
            <input
              type="text"
              class="font-medium"
              id="workaccomplished"
              name="workaccomplished"
              required
            />

            <div
              style="
                display: flex;
                align-items: center;
                gap: 10px;
                margin-top: 4px;
                margin-bottom: 16px;
              "
            >
              <input type="checkbox" id="isMakeup" name="isMakeup" style="width: auto; margin: 0" />
              <label class="formQuestions font-medium" for="isMakeup" style="margin: 0"
                >This is a makeup session</label
              >
            </div>
          </div>
        </div>

        <!-- Right Column (Tutee Information) -->
        <div class="form-column">
          <h2 class="black-heading">Tutee</h2>
          <div class="orange-box">
            <label class="formQuestions font-medium" for="tuteeName"
              >Tutee Name (Last Name, First Name)</label
            >
            <input
              type="text"
              class="font-medium"
              id="tuteeName"
              name="tuteeName"
              placeholder="e.g. Doe, Jane"
              required
            />
          </div>
        </div>
      </div>

      <div class="flex justify-center">
        <input type="submit" class="submit font-medium" value="Submit" />
      </div>
    </form>
  </div>
</main>

<script src="/js/tutorForm.js"></script>

<%- include('include/_footer') %> <%- include('include/_end') %>
